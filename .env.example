# Backdoor Sniper — environment example
# Copy to .env and adjust as needed. Never commit your real .env.

# SQLite database location (Prisma datasource).
DATABASE_URL="file:./db/custom.db"

# Optional: API keys for AI-assisted analysis features.
# Leave blank to disable external AI providers.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_API_KEY=""

# Optional: session secret for next-auth (generate a long random string in prod).
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"
