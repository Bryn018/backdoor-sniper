!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# OpenNext / Cloudflare build output
.open-next/
.wrangler/
.dev.vars

